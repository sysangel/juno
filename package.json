{
  "name": "juno",
  "version": "0.0.0-skeleton",
  "description": "Terminal agent UI — TypeScript + React + Ink rewrite (W1 skeleton).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "juno": "src/cli.ts"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "dev": "tsx watch src/cli.ts",
