{
  "name": "juno",
  "version": "0.1.0",
  "description": "Terminal agent UI — TypeScript + React + Ink rewrite (W1 skeleton).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.3"
  },
  "bin": {
    "juno": "src/cli.ts"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "selftest": "tsx scripts/selftest.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "supports-color": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@xterm/headless": "^6.0.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "ink-testing-library": "^4.0.0",
    "node-pty": "^1.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^2.1.0"
  }
}
