id` is the turn id. Good, my code is correct.\n\nNow Anthropic client. Let me write it.\n\n```ts\nimport type { AgentEvent } from '../core/events';\nimport type { ModelClient, ToolSpec, TurnInput, TurnMessage } from '../core/contracts';\n\nexport interface AnthropicConfig {\n  baseUrl: string;  // may be empty\n  apiKeyEnv: string;\n  defaultModel: string;\n}\n\nexport interface AnthropicDeps {\n  env?: NodeJS.ProcessEnv;\n  fetchImpl?: typeof fetch;\n}\n\ninterface AnthropicBlock {\n  type: 'text' | 'thinking' | 'tool_use';\n  id?: string;\n  name?: string;\n  argsBuffer: string;\n}\n\ninterface AnthropicEvent {\n  type: string;\n  index?: number;\n  content_block?: { type?: string; id?: string; name?: string; text?: string };\n  delta?: { type?: string; text?: string; thinking?: string; partial_json?: string; stop_reason?: string };\n  usage?: { input_tokens?: number; output_tokens?: number };\n  message?: { usage?: { input_tokens?: number; output_tokens?: number } };\n}\n```\n\nSSE reader same as before.\n\nMessage conversion for Anthropic:\n\n```ts\nfunction toAnthropicMessages(messages: TurnMessage[]): { system: string | undefined; messages: unknown[] } {\n  const systemParts: string[] = [];\n  const out: unknown[] = [];\n  for (const m of messages) {\n    switch (m.role) {\n      case 'system':\n        systemParts.push(m.content);\n        break;\n      case 'user':\n        out.push({ role: 'user', content: m.content });\n        break;\n      case 'assistant': {\n        if (m.toolCalls && m.toolCalls.length > 0) {\n          const content: unknown[] = [];\n          if (m.content) content.push({ type: 'text', text: m.content });\n          for (const tc of m.toolCalls) {\n            content.push({ type: 'tool_use', id: tc.toolCallId, name: tc.name, input: tc.args });\n          }\n          out.push({ role: 'assistant', content });\n        } else {\n          out.push({ role: 'assistant', content: m.content });\n        }\n        break;\n      }\n      case 'tool': {\n        // tool result goes as user message with tool_result content\n        out.push({ role: 'user', content: [{ type: 'tool_result', tool_use_id: m.toolCallId, content: m.content }] });\n        break;\n      }\n    }\n  }\n  return { system: systemParts.length > 0 ? systemParts.join('\\n\\n') : undefined, messages: out };\n}\n```\n\nHmm, but consecutive tool results should be in the same user message? Anthropic allows multiple tool_result blocks in one user message. But for simplicity, separate user messages each with one tool_result. Actually Anthropic requires tool_results to be in user messages and they can be grouped. Separate messages should work too. Let me keep simple.\n\nActually, there's a subtlety: if you have multiple tool results in a row, each as a separate user message, that should be fine for Anthropic.\n\nTools mapping:\n```ts\nfunction toAnthropicTools(tools: ToolSpec[]): unknown[] {\n  return tools.map((t) => ({ name: t.name, description: t.description, input_schema: t.inputSchema }));\n}\n```\n\nNow streamTurn:\n\n```ts\nasync *streamTurn(input, tools, signal) {\n  if (signal.aborted) { yield aborted; return; }\n  const apiKey = env[apiKeyEnv] ?? '';\n  if (!apiKey) { yield error; return; }\n  yield assistant-start;\n  \n  const model = input.model ?? config.defaultModel;\n  const baseUrl = config.baseUrl || 'https://api.anthropic.com';\n  const url = `${baseUrl}/v1/messages`;\n  \n  const messages: TurnMessage[] = [];\n  if (input.systemPrompt) messages.push({ role: 'system', content: input.systemPrompt });\n  messages.push(...input.messages);\n  const { system, messages: apiMessages } = toAnthropicMessages(messages);\n  \n  const body: Record<string, unknown> = {\n    model,\n    messages: apiMessages,\n    stream: true,\n    max_tokens: 4096,\n  };\n  if (system) body.system = system;\n  if (tools.length > 0) body.tools = toAnthropicTools(tools);\n  \n  // fetch with headers\n  try {\n    res = await fetchImpl(url, {\n      method: 'POST',\n      headers: { 'content-type': 'application/json', 'x-api-key': apiKey, 'anthropic-version': '2023-06-01' },\n      body: JSON.stringify(body),\n      signal,\n    });\n  } catch (e) { ... }\n  \n  // parse SSE\n  const blocks = new Map<number, AnthropicBlock>();\n  let stopReason: string | undefined;\n  let usageIn = 0, usageOut = 0, hasUsage = false;\n  let hasTools = false;\n  \n  for await (const line of readSseLines(res.body)) {\n    if (signal.aborted) { yield aborted; return; }\n    if (!line.startsWith('data:')) continue;\n    const data = line.slice(5).trim();\n    if (!data) continue;\n    let parsed; try { parsed = JSON.parse(data); } catch { continue; }\n    const evt = parsed as AnthropicEvent;\n    switch (evt.type) {\n      case 'message_start': {\n        if (evt.message?.usage) {\n          usageIn = evt.message.usage.input_tokens ?? 0;\n          usageOut = evt.message.usage.output_tokens ?? 0;\n          hasUsage = true;\n        }\n        break;\n      }\n      case 'content_block_start': {\n        const idx = evt.index ?? 0;\n        const cb = evt.content_block;\n        if (cb) {\n          blocks.set(idx, { type: (cb.type as 'text'|'thinking'|'tool_use') ?? 'text', id: cb.id, name: cb.name, argsBuffer: '' });\n        }\n        break;\n      }\n      case 'content_block_delta': {\n        const idx = evt.index ?? 0;\n        const block = blocks.get(idx);\n        const d = evt.delta;\n        if (!block || !d) break;\n        if (d.type === 'text_delta' && d.text) {\n          yield { type: 'text-delta', id: input.id, delta: d.text };\n        } else if (d.type === 'thinking_delta' && d.thinking) {\n          yield { type: 'reasoning-delta', id: input.id, delta: d.thinking };\n        } else if (d.type === 'input_json_delta' && d.partial_json) {\n          block.argsBuffer += d.partial_json;\n          yield { type: 'tool-call-delta', toolCallId: block.id ?? '', argsDelta: d.partial_json };\n        }\n        break;\n      }\n      case 'content_block_stop': {\n        const idx = evt.index ?? 0;\n        const block = blocks.get(idx);\n        if (block && block.type === 'tool_use') {\n          hasTools = true;\n          let args: unknown = {};\n          if (block.argsBuffer) {\n            try { args = JSON.parse(block.argsBuffer); } catch { args = block.argsBuffer; }\n          }\n          yield { type: 'tool-call', id: input.id, toolCallId: block.id ?? '', name: block.name ?? '', args };\n        }\n        break;\n      }\n      case 'message_delta': {\n        if (evt.delta?.stop_reason) stopReason = evt.delta.stop_reason;\n        if (evt.usage?.output_tokens) { usageOut = evt.usage.output_tokens; hasUsage = true; }\n        break;\n      }\n      case 'message_stop': break;\n      case 'ping': break;\n    }\n  }\n  \n  if (hasUsage) yield { type: 'usage', tokensIn: usageIn, tokensOut: usageOut };\n  yield { type: 'assistant-done', id: input.id, stopReason: mapAnthropicStop(stopReason, hasTools) };\n}\n```\n\nmapAnthropicStop:\n```ts\nfunction mapAnthropicStop(reason: string | undefined, hasTools: boolean): StopReason {\n  if (reason === 'end_turn') return 'end';\n  if (reason === 'tool_use') return 'tool_use';\n  if (reason === 'max_tokens') return 'max_tokens';\n  if (reason === 'stop_sequence') return 'end';\n  if (hasTools) return 'tool_use';\n  return 'end';\n}\n```\n\nNeed to import StopReason type. Actually I can just return the literal strings. Let me import the type for safety.\n\nNow the registry `index.ts`:\n\n```ts\nimport type { ModelClient } from '../core/contracts';\nimport type { ModelEntry } from '../services/catalog';\nimport { createOpenAICompatClient } from './openaiCompatClient';\nimport { createAnthropicClient } from './anthropicClient';\n\nexport interface ProviderDeps {\n  provider?: { baseUrl?: string; apiKeyEnv?: string };\n  env?: NodeJS.ProcessEnv;\n  fetchImpl?: typeof fetch;\n}\n\nexport type ProviderId = 'openai' | 'openrouter' | 'anthropic';\n\nexport function createModelClient(entry: ModelEntry, deps: ProviderDeps = {}): ModelClient {\n  const provider = deps.provider ?? {};\n  const apiKeyEnv = provider.apiKeyEnv ?? '';\n  const sharedDeps = { env: deps.env, fetchImpl: deps.fetchImpl };\n  switch (entry.provider) {\n    case 'openai':\n      return createOpenAICompatClient({\n        baseUrl: provider.baseUrl ?? 'https://api.openai.com/v1',\n        apiKeyEnv,\n        providerId: 'openai',\n        defaultModel: entry.id,\n      }, sharedDeps);\n    case 'openrouter':\n      return createOpenAICompatClient({\n        baseUrl: provider.baseUrl ?? 'https://openrouter.ai/api/v1',\n        apiKeyEnv,\n        providerId: 'openrouter',\n        defaultModel: entry.id,\n      }, sharedDeps);\n    case 'anthropic':\n      return createAnthropicClient({\n        baseUrl: provider.baseUrl ?? '',\n        apiKeyEnv,\n        defaultModel: entry.id,\n      }, sharedDeps);\n    default:\n      throw new Error('unknown provider: ' + entry.provider);\n  }\n}\n```\n\nWait, `sharedDeps` has `env` and `fetchImpl` which might be undefined. The client deps interfaces have them optional. But TS might complain about the type. `sharedDeps` would be `{ env: NodeJS.ProcessEnv | undefined; fetchImpl: typeof fetch | undefined }`. The client deps expect `env?: NodeJS.ProcessEnv` and `fetchImpl?: typeof fetch`. That should be compatible. Let me type it explicitly.\n\nActually, let me just pass `{ env: deps.env, fetchImpl: deps.fetchImpl }` inline to each. Or define:\n\n```ts\nconst sharedDeps = { env: deps.env, fetchImpl: deps.fetchImpl };\n```\n\nTS infers the type with optional properties. Should be fine since the target accepts undefined.\n\nHmm, actually `fetchImpl?: typeof fetch` means `typeof fetch | undefined`. And `deps.fetchImpl` is `typeof fetch | undefined`. So passing it is fine.\n\nNow the test file. Let me write it.\n\n```ts\nimport { describe, it, expect } from 'vitest';\nimport { createModelClient, type ProviderDeps } from '../src/providers/index';\nimport type { ModelEntry } from '../src/services/catalog';\nimport type { AgentEvent } from '../src/core/events';\nimport type { TurnInput, ToolSpec } from '../src/core/contracts';\n```\n\nWait, the test imports. The test file is at `tests/modelClients.fake.test.ts`. So imports are `../src/providers/index` etc. Let me check — repo root is `C:\\Users\\Core\\src\\juno`. Tests in `tests/`. Source in `src/`. So from `tests/modelClients.fake.test.ts`, import `../src/providers`.\n\nActually wait, vitest config might have aliases. But I'll use relative paths to be safe.\n\nLet me write helper:\n\n```ts\nfunction sseResponse(chunks: string[]): Response {\n  const encoder = new TextEncoder();\n  const stream = new ReadableStream<Uint8Array>({\n    start(controller) {\n      for (const c of chunks) controller.enqueue(encoder.encode(c));\n      controller.close();\n    },\n  });\n  return new Response(stream, { status: 200, headers: { 'content-type': 'text/event-stream' } });\n}\n\nfunction fakeFetch(chunks: string[], capture?: (body: unknown) => void): typeof fetch {\n  return async (input: RequestInfo | URL, init?: RequestInit): Promise<Response> => {\n    if (capture && init?.body) {\n      try { capture(JSON.parse(String(init.body))); } catch { /* ignore */ }\n    }\n    return sseResponse(chunks);\n  };\n}\n```\n\nModel entries:\n```ts\nconst openaiEntry: ModelEntry = { id: 'gpt-4.1', provider: 'openai', label: 'GPT-4.1', contextWindow: 128000 };\nconst openrouterEntry: ModelEntry = { id: 'anthropic/claude-sonnet-4', provider: 'openrouter', label: 'Claude via OR', contextWindow: 200000 };\nconst anthropicEntry: ModelEntry = { id: 'claude-sonnet-4-5', provider: 'anthropic', label: 'Claude', contextWindow: 200000 };\n```\n\nTurnInput:\n```ts\nconst input: TurnInput = { id: 'turn-1', messages: [{ role: 'user', content: 'hi' }] };\n```\n\nTools:\n```ts\nconst tools: ToolSpec[] = [];\n```\n\nDrain helper:\n```ts\nasync function drain(iter: AsyncIterable<AgentEvent>): Promise<AgentEvent[]> {\n  const out: AgentEvent[] = [];\n  for await (const e of iter) out.push(e);\n  return out;\n}\n```\n\nNow tests. Let me write them.\n\nTest 1: OpenAI text streaming.\n```ts\nconst chunks = [\n  'data: {\"choices\":[{\"delta\":{\"content\":\"Hello\"}}]}\\n\\n',\n  'data: {\"choices\":[{\"delta\":{\"content\":\" world\"}}]}\\n\\n',\n  'data: {\"choices\":[{\"delta\":{},\"finish_reason\":\"stop\"}],\"usage\":{\"prompt_tokens\":5,\"completion_tokens\":2}}\\n\\n',\n  'data: [DONE]\\n\\n',\n];\nconst deps: ProviderDeps = {\n  provider: { baseUrl: 'https://api.openai.com/v1', apiKeyEnv: 'OPENAI_API_KEY' },\n  env: { OPENAI_API_KEY: 'sk-test-secret' },\n  fetchImpl: fakeFetch(chunks),\n};\nconst client = createModelClient(openaiEntry, deps);\nconst events = await drain(client.streamTurn(input, tools, new AbortController().signal));\nexpect(events[0]).toEqual({ type: 'assistant-start', id: 'turn-1' });\nconst textDeltas = events.filter(e => e.type === 'text-delta');\nexpect(textDeltas.map(e => e.type === 'text-delta' ? e.delta : '')).toEqual(['Hello', ' world']);\nexpect(events[events.length - 1]).toEqual({ type: 'assistant-done', id: 'turn-1', stopReason: 'end' });\nconst usage = events.find(e => e.type === 'usage');\nexpect(usage).toEqual({ type: 'usage', tokensIn: 5, tokensOut: 2 });\n```\n\nTest 2: OpenAI tool call.\n```ts\nconst chunks = [\n  'data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"call_1\",\"function\":{\"name\":\"get_weather\",\"arguments\":\"\"}}]}}]}\\n\\n',\n  'data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"function\":{\"arguments\":\"{\\\\\"city\\\\\":\"}}]}}]}\\n\\n',\n  'data: {\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"function\":{\"arguments\":\"\\\\\"SF\\\\\"}\"}}]}}]}\\n\\n',\n  'data: {\"choices\":[{\"delta\":{},\"finish_reason\":\"tool_calls\"}]}\\n\\n',\n  'data: [DONE]\\n\\n',\n];\n```\n\nAssert tool-call-delta events exist, then a tool