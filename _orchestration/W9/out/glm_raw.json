faultModel: entry.id,\n      }, sharedDeps);\n    case 'openrouter':\n      return createOpenAICompatClient({\n        baseUrl: provider.baseUrl ?? 'https://openrouter.ai/api/v1',\n        apiKeyEnv,\n        providerId: 'openrouter',\n        defaultModel: entry.id,\n      }, sharedDeps);\n    case 'anthropic':\n      return createAnthropicClient({\n        baseUrl: provider.baseUrl ?? '',\n        apiKeyEnv,\n        defaultModel: entry.id,\n      }, sharedDeps);\n    default:\n      throw new Error('unknown provider: ' + entry.provider);\n  }\n}\n```\n\nWait, `sharedDeps` has `env` and `fetchImpl` which might be undefined. The client deps interfaces have them optional. But TS might complain about the type. `sharedDeps` would be `{ env: NodeJS.ProcessEnv | undefined; fetchImpl: typeof fetch | undefined }`. The client deps expect `env?: NodeJS.ProcessEnv` and `fetchImpl?: typeof fetch`. That should be compatible. Let me type it explicitly.\n\nActually, let me just pass `{ env: deps.env, fetchImpl: deps.fetchImpl }` inline to each. Or define:\n\n```ts\nconst sharedDeps = { env: deps.env, fetchImpl: deps.fetchImpl };\n```\n\nTS infers the type with optional properties. Should be fine since the target accepts undefined.\n\nHmm, actually `fetchImpl?: typeof fetch` means `typeof fetch | undefined`. And `deps.fetchImpl` is `typeof fetch | undefined`. So passing it is fine.\n\nNow the test file. Let me write it.\n\n```ts\nimport { describe, it, expect } from 'vitest';\nimport { createModelClient, type ProviderDeps } from '../src/providers/index';\nimport type { ModelEntry } from '../src/services/catalog';\nimport type { AgentEvent } from '../src/core/events';\nimport type { TurnInput, ToolSpec } from '../src/core/contracts';\n```\n\nWait, the test imports. The test file is at `tests/modelClients.fake.test.ts`. So imports are `../src/providers/index` etc. Let me check — repo root is `C:\\Users\\Core\\src\\juno`. Tests in `tests/`. Source in `src/`. So from `tests/modelClie