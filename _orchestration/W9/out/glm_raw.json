s(tools);\n      }\n      if (config.providerId === 'openrouter') {\n        body.provider = { data_collection: 'deny', allow_fallbacks: true };\n      }\n      if (input.systemPrompt) {\n        // prepend system message? Actually messages already may contain system. \n        // Let me not add separately for OpenAI compat; systemPrompt could be prepended.\n      }\n```\n\nHmm, `input.systemPrompt`. For OpenAI, I could prepend a system message. But messages may already have system. Let me just prepend if present and no system message exists. Actually, to keep simple, let me prepend systemPrompt as a system message at the start if provided.\n\nActually, let me handle it: if `input.systemPrompt` is set, prepend `{ role: 'system', content: input.systemPrompt }` to messages. But the messages array might already have system. The harness probably uses one or the other. Let me just prepend.\n\nWait, but `toOpenAIMessages` takes `input.messages`. Let me build the messages array:\n\n```ts\nconst messages: TurnMessage[] = [];\nif (input.systemPrompt) {\n  messages.push({ role: 'system', content: input.systemPrompt });\n}\nmessages.push(...input.messages);\n```\n\nThen `body.messages = toOpenAIMessages(messages)`.\n\nOK. Now the fetch:\n\n```ts\n      let res: Response;\n      try {\n        res = await fetchImpl(url, {\n          method: 'POST',\n          headers: {\n            'content-type': 'application/json',\n            authorization: `Bearer ${apiKey}`,\n          },\n          body: JSON.stringify(body),\n          signal,\n        });\n      } catch (e) {\n        if (signal.aborted || isAbortError(e)) {\n          yield { type: 'aborted' };\n          return;\n        }\n        yield { type: 'error', message: errMessage(e) };\n        yield { type: 'assistant-done', id: input.id, stopReason: 'error' };\n        return;\n      }\n\n      if (!res.ok || !res.body) {\n        yield { type: 'error', message: `HTTP ${res.status}` };\n        yield { type: 'assistant-done', id: input.id, stopReason: 'error' };\n        return;\n      }\n\n      const toolAccum = new Map<number, OpenAIToolCallAccum>();\n      let finishReason: string | null = null;\n      let usageIn = 0;\n      let usageOut = 0;\n      let hasUsage = false;\n\n      try {\n        for await (const line of readSseLines(res.body)) {\n          if (signal.aborted) {\n            yield { type: 'aborted' };\n            return;\n          }\n          if (!line.startsWith('data:')) continue;\n          const data = line.slice(5).trim();\n          if (data === '[DONE]') break;\n          if (data === '') continue;\n          let parsed: unknown;\n          try {\n            parsed = JSON.parse(data);\n          } catch {\n            continue;\n          }\n          const chunk = parseChunk(parsed);\n          if (!chunk) continue;\n          const choice = chunk.choices?.[0];\n          if (choice?.delta?.content) {\n            yield { type: 'text-delta', id: input.id, delta: choice.delta.content };\n          }\n          if (choice?.delta?.reasoning_content) {\n            yield { type: 'reasoning-delta', id: input.id, delta: choice.delta.reasoning_content };\n          }\n          if (choice?.delta?.tool_calls) {\n            for (const tc of choice.delta.tool_calls) {\n              let accum = toolAccum.get(tc.index);\n              if (!accum) {\n                accum = { index: tc.index, argsBuffer: '' };\n                toolAccum.set(tc.index, accum);\n              }\n              if (tc.id) accum.id = tc.id;\n              if (tc.function?.name) accum.name = tc.function.name;\n              if (tc.function?.arguments) {\n                accum.argsBuffer += tc.function.arguments;\n                yield { type: 'tool-call-delta', toolCallId: accum.id ?? '', argsDelta: tc.function.arguments };\n              }\n            }\n          }\n          if (choice?.finish_reason) {\n            finishReason = choice.finish_reason;\n          }\n          if (chunk.usage) {\n            usageIn = chunk.usage.prompt_tokens ?? usageIn;\n            usageOut = chunk.usage.completion_tokens ?? usageOut;\n            hasUsage = true;\n          }\n        }\n      } catch (e) {\n        if (signal.aborted || isAbortError(e)) {\n          yield { type: 'aborted' };\n          return;\n        }\n        yield { type: 'error', message: errMessage(e) };\n        yield { type: 'assistant-done', id: input.id, stopReason: 'error' };\n        return;\n      }\n\n      // emit tool calls\n      const hasTools = toolAccum.size > 0;\n      for (const [, accum] of toolAccum) {\n        let args: unknown = {};\n        if (accum.argsBuffer) {\n          try {\n            args = JSON.parse(accum.argsBuffer);\n          } catch {\n            args = accum.argsBuffer;\n          }\n        }\n        yield { type: 'tool-call', id: input.id, toolCallId: accum.id ?? '', name: accum.name ?? '', args };\n      }\n\n      if (hasUsage) {\n        yield { type: 'usage', tokensIn: usageIn, tokensOut: usageOut };\n      }\n\n      const stopReason = mapFinishReason(finishReason, hasTools);\n      yield { type: 'assistant-done', id: input.id, stopReason };\n    },\n  };\n}\n```\n\nWait, there's an issue with `tool-call-delta` — the `toolCallId` might be empty until the first chunk sets it. In OpenAI, the first tool_call chunk includes the `id`. So `accum.id` is set on first chunk. But I emit tool-call-delta in the same iteration as when id is set. Let me reorder: set id/name first, then emit delta. Actually in my code, I set `accum.id = tc.id` before emitting delta? Let me check: I do `if (tc.id) accum.id = tc.id;` then `if (tc.function?.arguments) { accum.argsBuffer += ...; yield tool-call-delta with accum.id }`. Yes, id is set first. Good. But the first chunk typically has id AND empty arguments, so no delta emitted. Subsequent chunks have arguments but no id. So toolCallId will be set. Good.\n\nHelper functions:\n\n```ts\nfunction isAbortError(e: unknown): boolean {\n  if (isObject(e) && typeof (e as { name?: unknown }).name === 'string') {\n    return (e as { name: string }).name === 'AbortError';\n  }\n  return false;\n}\n\nfunction errMessage(e: unknown): string {\n  if (isObject(e) && typeof (e as { message?: unknown }).message === 'string') {\n    return (e as { message: string }).message;\n  }\n  return String(e);\n}\n```\n\nNow the issue: `input.id` is used for text-delta and tool-call `id` field. The contract says `text-delta` has `id` (the turn id). And `tool-call` has `id` (turn id) plus `toolCallId`. Good.\n\nWait, looking at the contract again:\n- `text-delta`: `{ type: 'text-delta'; id: string; delta: string }` — id is turn id.\n- `tool-call`: `{ type: 'tool-call'; id: string; toolCallId: string; name: string; args: unknown }` — id is turn id.\n- `tool-call-delta`: `{ type: 'tool-call-delta'; toolCallId: string; argsDelta: string }` — no turn id.\n\nGood, my code matches.\n\nNow `input.id` — wait, TurnInput has `id: string`. But I wrote `input.model ?? config.defaultModel` for model. And `input.id` for the turn id. But hold on, in the registry, the model id is `input.model ?? entry.id`. And `entry.id` is the model id (like 'gpt-4.1'). And `input.id` is the turn id. These are different! Let me re-read.\n\nTurnInput: `id: string` (turn id, used to stamp assistant-start/done). `model?: string` (override model). The model sent on wire is `input.model ?? entry.id`.\n\nSo `config.defaultModel = entry.id` (the model id). And `input.id` is the turn id. Good, my code is correct.\n\nNow Anthropic client. Let me write it.\n\n```ts\nimport type { AgentEvent } from '../core/events';\nimport type { ModelClient, ToolSpec, TurnInput, TurnMessage } from '../core/contracts';\n\nexport interface AnthropicConfig {\n  baseUrl: string;  // may be empty\n  apiKeyEnv: string;\n  defaultModel: string;\n}\n\nexport interface AnthropicDeps {\n  env?: NodeJS.ProcessEnv;\n  fetchImpl?: typeof fetch;\n}\n\ninterface AnthropicBlock {\n  type: 'text' | 'thinking' | 'tool_use';\n  id?: string;\n  name?: string;\n  argsBuffer: string;\n}\n\ninterface AnthropicEvent {\n  type: string;\n  index?: number;\n  content_block?: { type?: string; id?: string; name?: string; text?: string };\n  delta?: { type?: string; text?: string; thinking?: string; partial_json?: string; stop_reason?: string };\n  usage?: { input_tokens?: number; output_tokens?: number };\n  message?: { usage?: { input_tokens?: number; output_tokens?: number } };\n}\n```\n\nSSE reader same as before.\n\nMessage conversion for Anthropic:\n\n```ts\nfunction toAnthropicMessages(messages: TurnMessage[]): { system: string | undefined; messages: unknown[] } {\n  const systemParts: string[] = [];\n  const out: unknown[] = [];\n  for (const m of messages) {\n    switch (m.role) {\n      case 'system':\n        systemParts.push(m.content);\n        break;\n      case 'user':\n        out.push({ role: 'user', content: m.content });\n        break;\n      case 'assistant': {\n        if (m.toolCalls && m.toolCalls.length > 0) {\n          const content: unknown[] = [];\n          if (m.content) content.push({ type: 'text', text: m.content });\n          for (const tc of m.toolCalls) {\n            content.push({ type: 'tool_use', id: tc.toolCallId, name: tc.name, input: tc.args });\n          }\n          out.push({ role: 'assistant', content });\n        } else {\n          out.push({ role: 'assistant', content: m.content });\n        }\n        break;\n      }\n      case 'tool': {\n        // tool result goes as user message with tool_result content\n        out.push({ role: 'user', content: [{ type: 'tool_result', tool_use_id: m.toolCallId, content: m.content }] });\n        break;\n      }\n    }\n  }\n  return { system: systemParts.length > 0 ? systemParts.join('\\n\\n') : undefined, messages: out };\n}\n```\n\nHmm, but consecutive tool results should be in the same user message? Anthropic allows multiple tool_result blocks in one