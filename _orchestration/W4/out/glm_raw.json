e';\nimport { ToolCallCard } from './ToolCallCard';\n\nconst DEPTH = detectColorDepth();\n\nfunction roleToken(role: Msg['role'], depth: ColorDepth): string {\n  switch (role) {\n    case 'user': return token('roleUser', depth);\n    case 'assistant': return token('roleAssistant', depth);\n    case 'system': return token('roleSystem', depth);\n    case 'tool': return token('textDim', depth);\n  }\n}\n\nexport interface MessageProps { msg: Msg; depth?: ColorDepth }\n\nexport function Message({ msg, depth }: MessageProps): ReactElement {\n  const d = depth ?? DEPTH;\n  const color = roleToken(msg.role, d);\n  return (\n    <Box flexDirection=\"column\">\n      {msg.reasoning ? (\n        <Box>\n          <Text color={token('textDim', d)} dimColor>thinking: {msg.reasoning}</Text>\n        </Box>\n      ) : null}\n      <Box flexDirection=\"column\">\n        {msg.blocks.map((block) => renderBlock(block, msg, d))}\n      </Box>\n    </Box>\n  );\n}\n\nfunction renderBlock(block: Block, msg: Msg, d: ColorDepth): ReactElement {\n  switch (block.kind) {\n    case 'text':\n      return <Text key={block.id} color={color}>{block.text}</Text>;  // hmm color scoping\n    case 'tool': {\n      const tool = msg.toolSnapshot?.[block.toolCallId];\n      return tool ? <ToolCallCard key={block.id} tool={tool} depth={d} /> : <Text key={block.id} color={token('textDim', d)}>[tool {block.toolCallId}]</Text>;\n    }\n  }\n}\n```\n\nHmm, color variable scoping in renderBlock. Let me restructure. Actually let me just inline.\n\nLet me reconsider — I want role color on text blocks. Let me pass color in.\n\n### StreamingMessage.tsx\nSame as Message but for live, with Spinner while streaming (msg.done === false).\n\n```tsx\nimport { Box, Text } from 'ink';\nimport { Spinner } from 'ink-spinner';\nimport type { Msg } from '../core/reducer';\nimport { token, detectColorDepth, type ColorDepth } from './theme';\nimport { Message } from './Message';\n\nconst DEPTH = detectColorDepth();\n\nexport interface StreamingMessageProps { live: Msg | null; depth?: ColorDepth }\n\nexport function StreamingMessage({ live, depth }: StreamingMessageProps): ReactElement | null {\n  if (!live) return null;\n  const d = depth ?? DEPTH;\n  return (\n    <Box flexDirection=\"column\">\n      <Message msg={live} depth={d} />\n      {!live.done ? <Box><Spinner /><Text> </Text></Box> : null}\n    </Box>\n  );\n}\n```\n\nWait Spinner needs a type prop? ink-spinner default is fine. Actually `Spinner` has default type 'dots'. OK.\n\nBut returning `null` from a component — ReactElement | null. Fine.\n\n### ToolCallCard.tsx\n```tsx\nimport { Box, Text } from 'ink';\nimport type { ToolState } from '../core/reducer';\nimport { token, detectColorDepth, type ColorDepth } from './theme';\n\nconst DEPTH = detectColorDepth();\n\nfunction statusToken(status: ToolState['status'], d: ColorDepth): string {\n  switch (status) {\n    case 'pending': return token('toolPending', d);\n    case 'running': return token('toolRunning', d);\n    case 'result': return token('toolResult', d);\n    case 'error': return token('toolError', d);\n  }\n}\n\nfunction statusGlyph(status: ToolState['status']): string {\n  switch (status) {\n    case 'pending': return '○';\n    case 'running': return '◐';\n    case 'result': return '●';\n    case 'error': return '✖';\n  }\n}\n\nfunction summarize(v: unknown): string {\n  if (v === undefined || v === null) return '';\n  if (typeof v === 'string') return v;\n  try { return JSON.stringify(v); } catch { return String(v); }\n}\n\nexport interface ToolCallCardProps { tool: ToolState; depth?: ColorDepth }\n\nexport function ToolCallCard({ tool, depth }: ToolCallCardProps): ReactElement {\n  const d = depth ?? DEPTH;\n  const color = statusToken(tool.status, d);\n  return (\n    <Box borderStyle=\"round\" borderColor={color} flexDirection=\"column\" paddingLeft={1} paddingRight={1}>\n      <Box>\n        <Text color={color}>{statusGlyph(tool.status)} </Text>\n        <Text color={token('text', d)} bold>{tool.name}</Text>\n        <Text color={token('textDim', d)}> [{tool.status}]</Text>\n      </Box>\n      {tool.status === 'result' && tool.result !== undefined ? (\n        <Text color={token('textDim', d)}>{summarize(tool.result)}</Text>\n      ) : null}\n      {tool.status === 'error' && tool.error ? (\n        <Text color={token('error', d)}>{tool.error}</Text>\n      ) : null}\n    </Box>\n  );\n}\n```\n\n### ModeBadge.tsx\n```tsx\nimport { Text } from 'ink';\nimport type { State } from '../core/reducer';\nimport { token, detectColorDepth, type ColorDepth } from './theme';\n\nconst DEPTH = detectColorDepth();\n\nexport interface ModeBadgeProps { mode: State['mode']; depth?: ColorDepth }\n\nexport function ModeBadge({ mode, depth }: ModeBadgeProps): ReactElement {\n  const d = depth ?? DEPTH;\n  const bg = token(`modeBadge.${mode}` as any, d);  // no any!\n  ...\n}\n```\n\nI can't use `as any`. The FlatTokenName type is `keyof Theme (minus modeBadge) | 'modeBadge.normal' | ...`. So I need to construct the token name properly. Let me do a switch:\n\n```tsx\nfunction modeToken(mode: State['mode'], d: ColorDepth): string {\n  switch (mode) {\n    case 'normal': return token('modeBadge.normal', d);\n    case 'plan': return token('modeBadge.plan', d);\n    case 'ultracode': return token('modeBadge.ultracode', d);\n  }\n}\n```\n\nGood, exhaustive.\n\n```tsx\nexport function ModeBadge({ mode, depth }: ModeBadgeProps): ReactElement {\n  const d = depth ?? DEPTH;\n  const bg = modeToken(mode, d);\n  return (\n    <Text backgroundColor={bg} color={token('textInverse', d)}> {mode.toUpperCase()} </Text>\n  );\n}\n```\n\n### StatusLine.tsx\n```tsx\nimport { Box, Text } from 'ink';\nimport type { StatusLineState } from '../core/selectors';\nimport { token, detectColorDepth, type ColorDepth } from './theme';\nimport { ModeBadge } from './ModeBadge';\n\nconst DEPTH = detectColorDepth();\n\nfunction contextBar(frac: number, d: ColorDepth): ReactElement {\n  const clamped = Math.max(0, Math.min(1, frac));\n  const width = 10;\n  const filled = Math.round(clamped * width);\n  const empty = width - filled;\n  return (\n    <Text>\n      <Text color={token('accent', d)}>{'█'.repeat(filled)}</Text>\n      <Text color={token('textDim', d)}>{'░'.repeat(empty)}</Text>\n    </Text>\n  );\n}\n\nexport interface StatusLineProps { status: StatusLineState; depth?: ColorDepth }\n\nexport function StatusLine({ status, depth }: StatusLineProps): ReactElement {\n  const d = depth ?? DEPTH;\n  return (\n    <Box flexDirection=\"column\">\n      <Box gap={1}>\n        <Text color={token('accent', d)} bold>{status.model}</Text>\n        <Text color={token('textDim', d)}>{status.cwd}</Text>\n        <Text color={token('textDim', d)}>tok:{status.tokens.total}</Text>\n        {contextBar(status.contextFraction, d)}\n        <ModeBadge mode={status.mode} depth={d} />\n      </Box>\n      <Box>\n        <Text color={token('text', d)}>{status.statusText}</Text>\n      </Box>\n    </Box>\n  );\n}\n```\n\n### InputBox.tsx\n```tsx\nimport { Box, Text } from 'ink';\nimport TextInput from 'ink-text-input';\nimport { token, detectColorDepth, type ColorDepth } from './theme';\n\nconst DEPTH = detectColorDepth();\n\nexport interface InputBoxProps { value: string; onChange:(v:string)=>void; onSubmit:(v:string)=>void; placeholder?:string; depth?:ColorDepth }\n\nexport function InputBox({ value, onChange, onSubmit, placeholder, depth }: InputBoxProps): ReactElement {\n  const d = depth ?? DEPTH;\n  return (\n    <Box>\n      <Text color={token('accent', d)}>❯ </Text>\n      <TextInput value={value} onChange={onChange} onSubmit={onSubmit} placeholder={placeholder ?? ''} />\n    </Box>\n  );\n}\n```\n\nink-text-input default export. Good.\n\n### SlashPalette.tsx\n```tsx\nimport { Box, Text } from 'ink';\nimport { token, detectColorDepth, type ColorDepth } from './theme';\n\nconst DEPTH = detectColorDepth();\n\nexport interface SlashPaletteProps { commands: Array<{ name:string; description:string }>; selectedIndex?:number; depth?:ColorDepth }\n\nexport function SlashPalette({ commands, selectedIndex = 0, depth }: SlashPaletteProps): ReactElement {\n  const d = depth ?? DEPTH;\n  return (\n    <Box flexDirection=\"column\" borderStyle=\"round\" borderColor={token('border', d)} paddingX={1}>\n      {commands.map((c, i) => {\n        const selected = i === selectedIndex;\n        return (\n          <Box key={c.name} gap={1}>\n            <Text color={selected ? token('accent', d) : token('textDim', d)}>{selected ? '▸' : ' '}</Text>\n            <Text color={selected ? token('accent', d) : token('text', d)} bold={selected}>/{c.name}</Text>\n            <Text color={token('textDim', d)}>{c.description}</Text>\n          </Box>\n        );\n      })}\n    </Box>\n  );\n}\n```\n\n### ModelPicker.tsx\n```tsx\nimport { Box, Text } from 'ink';\nimport type { ModelEntry } from '../services/catalog';\nimport { token, detectColorDepth, type ColorDepth } from './theme';\n\nconst DEPTH = detectColorDepth();\n\nexport interface ModelPickerProps { models: ReadonlyArray<ModelEntry>; selectedId?:string; depth?:ColorDepth }\n\nexport function ModelPicker({ models, selectedId, depth }: ModelPickerProps): ReactElement {\n  const d = depth ?? DEPTH;\n  return (\n    <Box flexDirection=\"column\" borderStyle=\"round\" borderColor={token('border', d)} paddingX={1}>\n      {models.map((m) => {\n        const selected = m.id === selectedId;\n        return (\n          <Box key={m.id} gap={1}>\n            <Text color={selected ? token('accent', d) : token('textDim', d)}>{selected ? '▸' : ' '}</Text>\n            <Text color={selected ? token('accent', d) : token('text', d)} bold={selected}>{m.label}</Text>\n            <Text color={token('textDim', d)}>{m.id}</Text>\n          </Box>\n        );\n      })}\n    </Box>\n  );\n}\n```\n\nModelEntry shape — I assume `{ id: string; label: string; ... }`. Risky but the brief says \"label + id\". I'll trust it.\n\n### PermissionPrompt.tsx\n```tsx\nimport { Box, Text, useInput } from 'ink';\nimport type { PermissionDecision, RiskLevel } from '../core/events';\nimport { token, detectColorDepth, type ColorDepth } from './theme';\n\nconst DEPTH = detectColorDepth();\n\nexport interface PermissionRequest { toolCallId:string; name:string; args:unknown; risk:RiskLevel }\nexport interface PermissionPromptProps { request: PermissionRequest; onDecision: (d: PermissionDecision) => void }\n\nfunction riskToken(risk: RiskLevel, d: ColorDepth): string {\n  switch (risk) {\n    case 'safe': return token('success', d);\n    case 'risky': return token('warning', d);\n    case 'dangerous': return token('error', d);\n  }\n}\n\nfunction summarize(v: unknown): string {\n  if (v === undefined || v === null) return '';\n  if (typeof v === 'string') return v;\n  try { return JSON.stringify(v); } catch { return String(v); }\n}\n\nexport function PermissionPrompt({ request, onDecision }: PermissionPromptProps): ReactElement {\n  const d = DEPTH;\n  useInput((input) => {\n    switch (input) {\n      case 'y': onDecision('allow-once'); break;\n      case 'a': onDecision('always-allow-pattern'); break;\n      case 'd': onDecision('deny'); break;\n      case '!': onDecision('dangerous-bypass'); break;\n      default: break;\n    }\n  });\n  const color = riskToken(request.risk, d);\n  return (\n    <Box flexDirection=\"column\" borderStyle=\"round\" borderColor={color} paddingX={1}>\n      <Box gap={1}>\n        <Text color={color} bold>⚠ Permission required</Text>\n      </Box>\n      <Box gap={1}>\n        <Text color={token('text', d)} bold>{request.name}</Text>\n        <Text color={token('textDim', d)}>risk: </Text>\n        <Text color={color} bold>{request.risk}</Text>\n      </Box>\n      <Text color={token('textDim', d)}>{summarize(request.args)}</Text>\n      <Box flexDirection=\"column\">\n        <Text color={token('text', d)}>[y] allow once   [a] always allow   [d] deny   [!] dangerous bypass</Text>\n      </Box>\n    </Box>\n  );\n}\n```\n\nWait — `useInput` calling onDecision multiple times if user presses key multiple times. The brief says \"call onDecision(d) exactly once\". Hmm. \"exactly once with the chosen PermissionDecision\" — meaning per decision event, call once. But if they press y twice, it'd call twice. Should I guard with state? The brief says \"no useState for app data (local UI cursor state for a list is OK)\". A \"decided\" flag is local UI state, arguably OK. But to be safe and pure, maybe guard. Actually the test only presses once and checks called once. Let me add a guard with useRef to be safe — useRef isn't useState. Actually let me use a ref to track if decided.\n\n```tsx\nimport { useRef } from 'react';\nconst decidedRef = useRef(false);\nuseInput((input) => {\n  if (decidedRef.current) return;\n  let decision: PermissionDecision | null = null;\n  switch (input) {\n    case 'y': decision = 'allow-once'; break;\n    case 'a': decision = 'always-allow-pattern'; break;\n    case 'd': decision = 'deny'; break;\n    case '!': decision = 'dangerous-bypass'; break;\n    default: break;\n  }\n  if (decision) {\n    decidedRef.current = true;\n    onDecision(decision);\n  }\n});\n```\n\nThis ensures exactly-once. Good. useRef is fine — not state for app data.\n\n### OverlayHost.tsx\n```tsx\nimport type { State } from '../core/reducer';\nimport type { ColorDepth } from './theme';\nimport { SlashPalette, type SlashPaletteProps } from './SlashPalette';\nimport { ModelPicker, type ModelPickerProps } from './ModelPicker';\nimport { PermissionPrompt, type PermissionPromptProps } from './PermissionPrompt';\n\nexport interface OverlayHostProps {\n  overlay: State['overlay'];\n  slash?: SlashPaletteProps;\n  modelPicker?: ModelPickerProps;\n  permission?: PermissionPromptProps;\n}\n\nexport function OverlayHost(props: OverlayHostProps): ReactElement | null {\n  switch (props.overlay) {\n    case 'none': return null;\n    